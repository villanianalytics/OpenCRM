APP_ENV=production
APP_URL=https://crm.example.com
APP_KEY=replace-with-64-random-hex-characters
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=opencrm
DB_USER=your_database_user
DB_PASS=use-a-strong-database-password
ADMIN_USERNAME=choose-an-admin-username
ADMIN_PASSWORD=use-a-unique-password-of-at-least-12-characters
ADMIN_EMAIL=admin@example.com
SESSION_SECURE=true
UPLOAD_MAX_MB=12
APP_TIMEZONE=America/New_York
